DATABASE_URL=postgresql+asyncpg://oms:oms@localhost:5432/oms
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# BAT module
BAT_EXPIRATION_DAYS=7
BAT_MAX_UPLOAD_MB=20
BAT_PUBLIC_BASE_URL=http://localhost:8000

# Storage: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/bat
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# Catalogue fournisseur — chemin vers le dossier contenant les mockups
# (par défaut un symlink dans ./storage/supplier-mockups, ou bien chemin direct
# vers `Mokeup fournisseur uniforme/` — utile sous Windows sans privilèges admin
# pour créer des symlinks)
# SUPPLIER_MOCKUPS_PATH=../Mokeup fournisseur uniforme
SUPPLIER_MOCKUPS_PATH=./storage/supplier-mockups
SUPPLIER_MOCKUPS_PUBLIC_PREFIX=/static/supplier-mockups

# SMTP / email
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_FROM=no-reply@example.com
SMTP_TEAM_ADDRESS=team@example.com

# Outbound webhook (Kanban / downstream system)
#
# The webhook stays disabled at runtime unless ALL THREE conditions are met:
#   1. KANBAN_WEBHOOK_ENABLED=true
#   2. KANBAN_WEBHOOK_URL is a non-empty https endpoint
#   3. KANBAN_WEBHOOK_SECRET is set (used to HMAC-sign each request)
#
# If any of the three is missing the webhook_service short-circuits and no
# request is ever signed or sent. Setting ENABLED=true alone is a no-op —
# this is intentional, so partial config never leaks production traffic.
KANBAN_WEBHOOK_ENABLED=false
KANBAN_WEBHOOK_URL=
KANBAN_WEBHOOK_SECRET=

# Admin endpoints (/admin/*)
#
# Required by the X-Admin-Token guard. While unset, every admin route returns
# 503 (fail-closed). Generate with:  python -c 'import secrets; print(secrets.token_urlsafe(32))'
ADMIN_TOKEN=
